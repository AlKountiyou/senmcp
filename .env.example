RUN_MODE=local

# Trust & safety / network
ALLOWLIST_DOMAINS=example.org,example.com

# MCP HTTP defaults
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp

# Audit log locations
AUDIT_OPENDATA_PATH=./logs/audit-opendata.jsonl
AUDIT_SERVICES_PATH=./logs/audit-services.jsonl
AUDIT_AGENT_PATH=./logs/audit-agent.jsonl

