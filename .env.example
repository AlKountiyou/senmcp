RUN_MODE=local

# Trust & safety / network
# JSON array of domains that outbound HTTP requests are allowed to reach.
# Defaults below are suitable for ANSD live mode.
ALLOWLIST_DOMAINS=["ansd.sn","agridata.ansd.sn"]

# Outbound HTTP behavior
# Maximum number of HTTP requests per second to a single host.
HTTP_RATE_LIMIT_PER_HOST=1.0
# TTL (in seconds) for HTTP disk cache entries.
HTTP_CACHE_TTL_SECONDS=86400
# Per-request timeout in seconds for outbound HTTP calls.
HTTP_TIMEOUT_SECONDS=10.0
# Maximum number of bytes to read from any single HTTP response body.
HTTP_MAX_BYTES=10000000

# MCP HTTP defaults
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp

# Audit log locations
AUDIT_OPENDATA_PATH=./logs/audit-opendata.jsonl
AUDIT_SERVICES_PATH=./logs/audit-services.jsonl
AUDIT_AGENT_PATH=./logs/audit-agent.jsonl

